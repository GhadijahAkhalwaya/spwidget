{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spwidget",
  "version": "0.1.0",
  "identifier": "com.local.jira-points-widget",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Spwidget",
        "width": 400,
        "height": 234,
        "minWidth": 400,
        "minHeight": 234,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": false,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "category": "Productivity",
    "shortDescription": "Jira story points resolved in last 90 days",
    "longDescription": "Always-on macOS desktop widget that shows how many Jira story points you've resolved in the last 90 days."
  }
}
